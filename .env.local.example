# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Apenas para rodar migrations (npm run db:migrate)
# Supabase Dashboard → Settings → Database → Connection string → URI (porta 5432)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# OpenAI (chunk analysis + Whisper transcription)
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Genius (2nd lyrics fallback — genius.com/api-clients → Client Access Token)
GENIUS_API_KEY=

# Spotify
# developer.spotify.com/dashboard → Client ID + Secret
# Redirect URIs a adicionar no dashboard:
#   Dev (ngrok):  https://SEU-ID.ngrok-free.app/api/spotify/callback
#   Produção:     https://lexuri.app/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Só necessário em dev com ngrok — em produção deixe vazio
SPOTIFY_REDIRECT_URI=

# Happi.dev (fallback lyrics source when lrclib + Genius have no results)
HAPPI_API_KEY=

# Stripe (payments)
# Dev: use test keys (sk_test_* / pk_test_*) from dashboard.stripe.com → Test mode
# Webhook local: run `stripe listen --forward-to localhost:3000/api/payments/webhook`
#   and paste the printed whsec_... below (changes each stripe listen session)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=

# Email (Resend)
RESEND_API_KEY=
# Leave empty in dev — falls back to onboarding@resend.dev automatically
# Production: set to "Lexuri <noreply@lexuri.app>" after verifying domain in Resend
RESEND_FROM=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cron secret: any string locally. Use `openssl rand -hex 32` for production.
# Test cron manually: curl -X GET http://localhost:3000/api/emails/daily-reminder \
#   -H "Authorization: Bearer <your-secret>"
CRON_SECRET=

# YouTube (optional — for age-restricted or geo-blocked videos)
YOUTUBE_COOKIES=
#youtube-api
YOUTUBE_API_KEY