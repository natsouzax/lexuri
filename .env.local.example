# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (chunk analysis + Whisper transcription)
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Genius (legacy song search — replaced by lrclib)
GENIUS_API_KEY=

# Spotify (resolve Spotify track URLs → title + artist)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Happi.dev (fallback lyrics source when lrclib has no results)
HAPPI_API_KEY=

# Stripe (payments)
# Dev: use test keys (sk_test_* / pk_test_*) from dashboard.stripe.com → Test mode
# Webhook local: run `stripe listen --forward-to localhost:3000/api/payments/webhook`
#   and paste the printed whsec_... below (changes each stripe listen session)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=

# Email (Resend)
RESEND_API_KEY=
# Leave empty in dev — falls back to onboarding@resend.dev automatically
# Production: set to "Lexuri <noreply@lexuri.app>" after verifying domain in Resend
RESEND_FROM=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cron secret: any string locally. Use `openssl rand -hex 32` for production.
# Test cron manually: curl -X GET http://localhost:3000/api/emails/daily-reminder \
#   -H "Authorization: Bearer <your-secret>"
CRON_SECRET=

# YouTube (optional — for age-restricted or geo-blocked videos)
YOUTUBE_COOKIES=
