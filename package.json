    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^12.40.0",
    "next": "16.2.6",
    "openai": "^6.39.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
